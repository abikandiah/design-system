{
	"name": "@abumble/design-system",
	"version": "0.0.49",
	"files": [
		"dist",
		"src/styles.css",
		"src/themes"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./components/*": {
			"import": "./dist/components/*.js",
			"types": "./dist/components/*/index.d.ts"
		},
		"./hooks/use-delayed-loading": {
			"import": "./dist/use-delayed-loading.js",
			"types": "./dist/hooks/use-delayed-loading/use-delayed-loading.d.ts"
		},
		"./utils": {
			"import": "./dist/utils.js",
			"types": "./dist/utils/utils.d.ts"
		},
		"./constants": {
			"import": "./dist/constants.js",
			"types": "./dist/constants/constants.d.ts"
		},
		"./types": {
			"import": "./dist/types.js",
			"types": "./dist/types/types.d.ts"
		},
		"./hooks/use-mobile": {
			"import": "./dist/use-mobile.js",
			"types": "./dist/hooks/use-mobile.d.ts"
		},
		"./styles.css": "./src/styles.css",
		"./themes": {
			"import": "./dist/themes.js",
			"types": "./dist/themes/index.d.ts"
		},
		"./themes/linen.css": "./src/themes/linen.css",
		"./themes/steel.css": "./src/themes/steel.css",
		"./themes/sage.css": "./src/themes/sage.css",
		"./themes/dusk.css": "./src/themes/dusk.css",
		"./themes/canopy.css": "./src/themes/canopy.css"
	},
	"scripts": {
		"version": "npm run build",
		"postversion": "git push",
		"build:js": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
		"build": "npm run clean && npm run build:js",
		"clean": "rimraf dist",
		"prepublishOnly": "npm run build",
		"publish:npm": "npm publish --access public",
		"dev": "vite",
		"sandbox": "vite --config sandbox/vite.config.ts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"dependencies": {
		"tw-animate-css": "^1.3.6"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.1",
		"@eslint/js": "^9.39.1",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@storybook/addon-a11y": "10.2.17",
		"@storybook/addon-docs": "10.2.17",
		"@storybook/addon-onboarding": "10.2.17",
		"@storybook/addon-vitest": "10.2.17",
		"@storybook/react-vite": "10.2.17",
		"@tailwindcss/vite": "^4.0.6",
		"@types/node": "^24.10.0",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@vitejs/plugin-react": "^5.1.0",
		"@vitest/browser-playwright": "^4.0.9",
		"@vitest/coverage-v8": "^4.0.9",
		"autoprefixer": "^10.4.22",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"embla-carousel": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"eslint-plugin-storybook": "10.2.17",
		"globals": "^16.5.0",
		"lucide-react": "^0.544.0",
		"playwright": "^1.56.1",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"rimraf": "^6.1.2",
		"storybook": "10.2.17",
		"tailwind-merge": "^3.0.2",
		"tailwindcss": "^4.1.17",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.46.3",
		"vite": "^7.2.2",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.0.9"
	},
	"peerDependencies": {
		"@radix-ui/react-checkbox": "^1.3.2",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.6",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-separator": "^1.1.7",
		"@radix-ui/react-slot": "^1.2.3",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"embla-carousel": "^8.6.0",
		"embla-carousel-react": "^8.6.0",
		"lucide-react": ">=0.544.0",
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0",
		"sonner": "^2.0.0",
		"tailwind-merge": "^3.0.2",
		"tailwindcss": ">=4.0.0"
	},
	"license": "MIT"
}
